{% block title %}HelloAsso Widgets - Édition du stream{% endblock %}


{% extends "layout.html.twig" %}
{% block content %}

		<div class="container">
			<h1 class="my-4 text-center">Édition du stream</h1>

		<a href="/admin" class="btn btn-secondary mb-4">Retour</a>

		{# ── Mode test ─────────────────────────────────────────────── #}
		<div class="card mb-4 {{ charityStream.is_test_mode ? 'border-warning' : '' }}">
			<div class="card-header d-flex justify-content-between align-items-center {{ charityStream.is_test_mode ? 'bg-warning bg-opacity-25' : '' }}">
				<h5 class="mb-0">🧪 Mode test</h5>
				<form method="POST" class="d-inline">
					{% if charityStream.is_test_mode %}
						<button type="submit" class="btn btn-sm btn-outline-danger" name="toggle_test_mode" value="1">❌ Désactiver le mode test</button>
					{% else %}
						<button type="submit" class="btn btn-sm btn-outline-warning" name="toggle_test_mode" value="1">🧪 Activer le mode test</button>
					{% endif %}
				</form>
			</div>
			{% if charityStream.is_test_mode %}
			<div class="card-body">
				<div class="row align-items-end">
					<div class="col-md-4">
						<p class="mb-1 fw-semibold">Montant test actuel : <span id="testAmountDisplay">{{ (charityStream.test_amount / 100) | number_format(2, ',', ' ') }} €</span></p>
						<form method="POST" class="d-inline">
							<button type="submit" class="btn btn-sm btn-outline-secondary" name="reset_test_amount" value="1">🔄 Remettre à zéro</button>
						</form>
					</div>
					<div class="col-md-8">
						<form id="simulateDonationForm" class="row g-2 align-items-end">
							<div class="col-md-3">
								<label for="sim_pseudo" class="form-label mb-0">Pseudo</label>
								<input type="text" class="form-control form-control-sm" id="sim_pseudo" value="Testeur" required>
							</div>
							<div class="col-md-2">
								<label for="sim_amount" class="form-label mb-0">Montant (€)</label>
								<input type="number" class="form-control form-control-sm" id="sim_amount" value="10" min="1" step="1" required>
							</div>
							<div class="col-md-4">
								<label for="sim_message" class="form-label mb-0">Message</label>
								<input type="text" class="form-control form-control-sm" id="sim_message" value="Don de test">
							</div>
							<div class="col-md-3">
								<button type="submit" class="btn btn-sm btn-warning w-100">💸 Simuler un don</button>
							</div>
						</form>
					</div>
				</div>
				<div id="simulateAlert" class="mt-2" style="display:none;"></div>
			</div>
			{% endif %}
		</div>

		{% for key, msgs in messages|default({}) %}
			{% for msg in msgs %}
				<div class="alert alert-{{ key == 'error' ? 'danger' : key }} alert-dismissible fade show" role="alert">
					{{ msg }}
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			{% endfor %}
		{% endfor %}

		{# ── Événement parent (lier / délier) ──────────────────────── #}
		<div class="card mb-4">
			<div class="card-header">
				<h5 class="mb-0">📅 Événement parent</h5>
			</div>
			<div class="card-body">
				{% if parentEvent %}
					<div class="d-flex align-items-center justify-content-between">
						<div>
							<span class="fw-semibold">{{ parentEvent.title }}</span>
							<a href="/admin/event/{{ parentEvent.guid }}/edit" class="btn btn-sm btn-outline-primary ms-2">🔗 Voir l'événement</a>
						</div>
						<form method="POST" class="d-inline" onsubmit="return confirm('Délier ce stream de l\'événement « {{ parentEvent.title | e('js') }} » ?')">
							<button type="submit" class="btn btn-sm btn-outline-danger" name="unlink_event" value="1">❌ Délier</button>
						</form>
					</div>
				{% else %}
					<form method="POST" class="d-flex align-items-end gap-3">
						<div class="flex-grow-1">
							<label for="event_id" class="form-label fw-semibold">Lier à un événement</label>
							<select class="form-select" id="event_id" name="event_id" required>
								<option value="">— Sélectionner un événement —</option>
								{% for event in availableEvents %}
									<option value="{{ event.id }}">{{ event.title }}</option>
								{% endfor %}
							</select>
						</div>
						<button type="submit" class="btn btn-success" name="link_event" value="1">🔗 Lier</button>
					</form>
					{% if availableEvents is empty %}
						<p class="text-muted mt-2 mb-0">Aucun événement disponible. <a href="/admin?createEvent=1">Créer un événement</a>.</p>
					{% endif %}
				{% endif %}
			</div>
		</div>

			{# ── Informations du stream ────────────────────────────────── #}
			<div class="card mb-4">
				<div class="card-header">
					<h5 class="mb-0">📋 Informations du stream</h5>
				</div>
				<div class="card-body">
					<form method="POST">
						<div class="row">
							<div class="col-md-9">
								<div class="mb-3">
									<label for="stream_title" class="form-label fw-semibold">Titre</label>
									<input type="text" class="form-control" id="stream_title" name="stream_title" value="{{ charityStream.title }}" required>
								</div>
							</div>
							<div class="col-md-3 d-flex align-items-end">
								<div class="mb-3">
									<button type="submit" class="btn btn-primary" name="save_stream_info">💾 Enregistrer</button>
								</div>
							</div>
						</div>
					</form>
				</div>
			</div>

			{# ── Objectifs de collecte ───────────────────────────────── #}
			<div class="card mb-4">
				<div class="card-header">
					<h5 class="mb-0">🎯 Objectifs de collecte</h5>
				</div>
				<div class="card-body">
					<form method="POST">
						<input type="hidden" name="save_goals" value="1">
						<div id="goalsManager">
							<div class="goals-chips d-flex flex-wrap gap-2 mb-3" style="min-height:38px;"></div>
							<div class="input-group mb-3" style="max-width:320px;">
								<input type="number" class="form-control goals-add-input" placeholder="Montant en € (ex: 500)" min="1" step="1">
								<button type="button" class="btn btn-outline-primary goals-add-btn">＋ Ajouter</button>
							</div>
							<div class="goals-hidden">
								{% for g in streamGoals %}
								<input type="hidden" name="goal_amounts[]" value="{{ g }}">
								{% endfor %}
							</div>
						</div>
					</form>
				</div>
			</div>

			<h5 class="d-flex align-items-center gap-2">
				Formulaire HelloAsso lié
				{% if charityStream.form_type == 'CrowdFunding' %}
					<span class="badge bg-info">🚀 Crowdfunding</span>
				{% else %}
					<span class="badge bg-success">🎁 Don</span>
				{% endif %}
				<a href="{{ donationUrl }}" target="_blank" class="btn btn-sm btn-outline-primary">🔗 Ouvrir le formulaire</a>
			</h5>

			<div class="accordion mt-4 mb-5" id="widgetsAccordion">

				{# ── Widget barre de don ────────────────────────────────── #}
				<div class="accordion-item">
					<h2 class="accordion-header" id="headingDonationBar">
						<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDonationBar" aria-expanded="true" aria-controls="collapseDonationBar">
							🎯 Widget barre de don
						</button>
					</h2>
					<div id="collapseDonationBar" class="accordion-collapse collapse show" aria-labelledby="headingDonationBar" data-bs-parent="#widgetsAccordion">
						<div class="accordion-body">
							<form id="donationBarForm" method="POST">
								<div class="row">
									<div class="col-md-6">
										<div class="mb-3">
											<label for="text_color_main" class="form-label">Couleur du texte primaire</label>
											<input type="color" class="form-control form-control-color" id="text_color_main" name="text_color_main" value="{{ donationGoalWidget.text_color_main }}">
										</div>
										<div class="mb-3">
											<label for="text_color_alt" class="form-label">Couleur du texte secondaire</label>
											<input type="color" class="form-control form-control-color" id="text_color_alt" name="text_color_alt" value="{{ donationGoalWidget.text_color_alt }}">
										</div>
										<div class="mb-3">
											<label for="text_content" class="form-label">Texte</label>
											<input type="text" class="form-control" id="text_content" name="text_content" value="{{ donationGoalWidget.text_content }}">
										</div>
									</div>
									<div class="col-md-6">
										<div class="mb-3">
											<label for="bar_color" class="form-label">Couleur de la barre</label>
											<input type="color" class="form-control form-control-color" id="bar_color" name="bar_color" value="{{ donationGoalWidget.bar_color }}">
										</div>
										<div class="mb-3">
											<label for="background_color" class="form-label">Couleur du fond</label>
											<input type="color" class="form-control form-control-color" id="background_color" name="background_color" value="{{ donationGoalWidget.background_color }}">
										</div>
									</div>
								</div>
								<div class="progress">
									<div class="back" style="background:{{ donationGoalWidget.background_color }};color:{{ donationGoalWidget.text_color_main }}">
										<p id="back-goal-current">{{ (streamGoals[0] ?? 1000) / 2 }} €</p>
										<p id="back-title">{{ donationGoalWidget.text_content }}</p>
										<p id="back-goal-total">{{ streamGoals[0] ?? 1000 }} €</p>
									</div>
									<div class="front" style="background:{{ donationGoalWidget.bar_color }};color:{{ donationGoalWidget.text_color_alt }}">
										<p id="front-goal-current">{{ (streamGoals[0] ?? 1000) / 2 }} €</p>
										<p id="front-title">{{ donationGoalWidget.text_content }}</p>
										<p id="front-goal-total">{{ streamGoals[0] ?? 1000 }} €</p>
									</div>
								</div>
								<div class="d-flex align-items-center justify-content-between mt-3">
									<h6 class="mb-0">
										URL : <a href="{{ widgetDonationGoalUrl }}" target="_blank">{{ widgetDonationGoalUrl }}</a>
									</h6>
									<button type="submit" class="btn btn-primary" name="save_donation_goal">💾 Enregistrer</button>
								</div>
							</form>
						</div>
					</div>
				</div>

				{# ── Widget alerte ──────────────────────────────────────── #}
				<div class="accordion-item">
					<h2 class="accordion-header" id="headingAlertBox">
						<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAlertBox" aria-expanded="false" aria-controls="collapseAlertBox">
							🔔 Widget alerte
						</button>
					</h2>
					<div id="collapseAlertBox" class="accordion-collapse collapse" aria-labelledby="headingAlertBox" data-bs-parent="#widgetsAccordion">
						<div class="accordion-body">
							<form id="alertBoxForm" method="POST" enctype="multipart/form-data">
								<div class="row">
									<div class="col-md-6">
										<div class="mb-3">
											<label for="image" class="form-label">Fichier image</label>
											{% if alertBoxWidget.image %}
												<div class="form-text">
													Déjà chargé:
													<a href="{{ alertBoxWidgetPictureUrl }}" target="_blank">{{ alertBoxWidget.image }}</a>
												</div>
											{% endif %}
											<input type="file" class="form-control" id="image" name="image"/>
										</div>
										<div class="mb-3">
											<label for="alert_duration" class="form-label">Durée de l'alerte (secondes)</label>
											<input type="number" class="form-control" id="alert_duration" name="alert_duration" value="{{ alertBoxWidget.alert_duration }}">
										</div>
										<div class="mb-3">
											<label for="sound" class="form-label">Fichier de son</label>
											{% if alertBoxWidget.sound %}
												<div class="form-text">
													Déjà chargé:
													<a href="{{ alertBoxWidgetSoundUrl }}" target="_blank">{{ alertBoxWidget.sound }}</a>
												</div>
											{% endif %}
											<input type="file" class="form-control" id="sound" name="sound"/>
										</div>
										<div class="mb-3">
											<label for="sound_volume" class="form-label">Volume du son (0-100)</label>
											<input type="number" class="form-control" id="sound_volume" name="sound_volume" value="{{ alertBoxWidget.sound_volume }}">
										</div>
									</div>
									<div class="col-md-6">
										<div class="mb-3">
											<label for="message_template" class="form-label">Template de message</label>
											<div class="form-text">
												C'est le message qui s'affichera lors d'un don.<br/>
												Paramètres disponibles :
												<ul>
													<li><code>{pseudo}</code> le pseudo du donateur</li>
													<li><code>{amount}</code> le montant du don</li>
													<li><code>{message}</code> le message du donateur</li>
												</ul>
												Vous pouvez formater le texte avec du HTML.
											</div>
											<textarea class="form-control" id="message_template" name="message_template" rows="5">{{ alertBoxWidget.message_template }}</textarea>
										</div>
									</div>
								</div>
								<div class="d-flex align-items-center justify-content-between mt-3">
									<h6 class="mb-0">
										URL : <a href="{{ widgetAlertBoxUrl }}" target="_blank">{{ widgetAlertBoxUrl }}</a>
									</h6>
									<div>
										<button type="button" id="previewBtn" class="btn btn-info">👁️ Prévisualiser</button>
										<button type="submit" class="btn btn-primary" name="save_alert_box">💾 Enregistrer</button>
									</div>
								</div>
							</form>
							<div class="widget-alert-box mt-3" style="min-height: 300px; border: 1px dashed #ccc; padding: 10px"></div>
						</div>
					</div>
				</div>

				{# ── Widget carte de don ────────────────────────────────── #}
				{% if cardWidget %}
				<div class="accordion-item">
					<h2 class="accordion-header" id="headingCardWidget">
						<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCardWidget" aria-expanded="false" aria-controls="collapseCardWidget">
							🃏 Widget carte de don
						</button>
					</h2>
					<div id="collapseCardWidget" class="accordion-collapse collapse" aria-labelledby="headingCardWidget" data-bs-parent="#widgetsAccordion">
						<div class="accordion-body">
							<form id="cardWidgetForm" method="POST" enctype="multipart/form-data">
								<div class="row">
									<div class="col-md-6">
										<div class="mb-3">
											<label for="card_image" class="form-label">Image de fond</label>
											{% if cardWidget.image %}
												<div class="form-text">
													Déjà chargée :
													<a href="{{ cardWidgetPictureUrl }}" target="_blank">{{ cardWidget.image }}</a>
												</div>
											{% endif %}
											<input type="file" class="form-control" id="card_image" name="card_image" accept="image/*"/>
										</div>
										<div class="mb-3">
											<label for="card_tag" class="form-label">Tag</label>
											<input type="text" class="form-control" id="card_tag" name="card_tag" value="{{ cardWidget.tag }}" placeholder="Ex: URGENCE NATURE">
										</div>
										<div class="mb-3">
											<label for="card_title" class="form-label">Titre</label>
											<input type="text" class="form-control" id="card_title" name="card_title" value="{{ cardWidget.title }}" placeholder="Ex: Protégeons nos forêts anciennes">
										</div>
									<div class="mb-3">
										<label for="card_description" class="form-label">Description</label>
										<textarea class="form-control" id="card_description" name="card_description" rows="3" placeholder="Description de la campagne">{{ cardWidget.description }}</textarea>
									</div>
								</div>
									<div class="col-md-6">
										<h6>Couleurs</h6>
										<div class="mb-3">
											<label for="card_background_color" class="form-label">Fond de la carte</label>
											<input type="color" class="form-control form-control-color" id="card_background_color" name="card_background_color" value="{{ cardWidget.background_color }}">
										</div>
										<div class="mb-3">
											<label for="card_text_color" class="form-label">Texte</label>
											<input type="color" class="form-control form-control-color" id="card_text_color" name="card_text_color" value="{{ cardWidget.text_color }}">
										</div>
										<div class="mb-3">
											<label for="card_bar_color" class="form-label">Barre de progression</label>
											<input type="color" class="form-control form-control-color" id="card_bar_color" name="card_bar_color" value="{{ cardWidget.bar_color }}">
										</div>
										<div class="mb-3">
											<label for="card_bar_background_color" class="form-label">Fond de la barre</label>
											<input type="color" class="form-control form-control-color" id="card_bar_background_color" name="card_bar_background_color" value="{{ cardWidget.bar_background_color }}">
										</div>
										<div class="mb-3">
											<label for="card_tag_color" class="form-label">Texte du tag</label>
											<input type="color" class="form-control form-control-color" id="card_tag_color" name="card_tag_color" value="{{ cardWidget.tag_color }}">
										</div>
										<div class="mb-3">
											<label for="card_tag_background_color" class="form-label">Fond du tag</label>
											<input type="color" class="form-control form-control-color" id="card_tag_background_color" name="card_tag_background_color" value="{{ cardWidget.tag_background_color }}">
										</div>
									</div>
								</div>

								{# ── Prévisualisation ── #}
								<div class="card-widget-preview mt-3 p-3" style="border: 1px dashed #555; border-radius: 12px;">
									<div id="cardPreview" style="display:flex; max-width:720px; border-radius:16px; overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,0.10); background-color:{{ cardWidget.background_color }}; color:{{ cardWidget.text_color }};">
										<div id="cardPreviewImage" style="flex:0 0 220px; min-height:280px; background-size:cover; background-position:center; {% if cardWidgetPictureUrl %}background-image:url('{{ cardWidgetPictureUrl }}');{% else %}background:#374151;{% endif %}"></div>
										<div style="flex:1; padding:28px 32px; display:flex; flex-direction:column; justify-content:center; gap:14px;">
											<div id="cardPreviewTag" style="display:inline-flex; align-items:center; gap:6px; font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:5px 14px; border-radius:999px; width:fit-content; color:{{ cardWidget.tag_color }}; background-color:{{ cardWidget.tag_background_color }};">
												✏️ {{ cardWidget.tag }}
											</div>
											<div id="cardPreviewTitle" style="font-size:24px; font-weight:800; line-height:1.15;">{{ cardWidget.title }}</div>
											<div id="cardPreviewDesc" style="font-size:13px; line-height:1.6; opacity:0.8;">{{ cardWidget.description }}</div>
											<div>
												<div id="cardPreviewAmount" style="font-size:28px; font-weight:800;">{{ (streamGoals[0] ?? 1000) / 2 }} €</div>
												<div style="display:flex; align-items:center; gap:12px;">
													<div style="flex:1; height:12px; border-radius:999px; overflow:hidden; background-color:{{ cardWidget.bar_background_color }};">
														<div id="cardPreviewBarFill" style="height:100%; border-radius:999px; width:50%; background-color:{{ cardWidget.bar_color }};"></div>
													</div>
													<div id="cardPreviewGoal" style="font-size:13px; white-space:nowrap;">Objectif : <strong>{{ streamGoals[0] ?? 1000 }} €</strong></div>
												</div>
												<div style="display:flex; gap:24px; margin-top:6px; font-size:13px; opacity:0.75;">
													<span><strong id="cardPreviewPct">50%</strong> collectés</span>
													<span><strong>0</strong> donateurs</span>
												</div>
											</div>
											<a href="{{ donationUrl }}" target="_blank" rel="noopener noreferrer" id="cardPreviewCta"
											   style="display:inline-flex; align-items:center; gap:6px; font-size:13px; font-weight:600; text-decoration:none; padding:8px 20px; border-radius:999px; width:fit-content; color:{{ cardWidget.tag_color }}; background-color:{{ cardWidget.tag_background_color }};">
												❤️ Je participe
											</a>
										</div>
									</div>
								</div>

								<div class="d-flex align-items-center justify-content-between mt-3">
									<h6 class="mb-0">
										URL : <a href="{{ widgetCardUrl }}" target="_blank">{{ widgetCardUrl }}</a>
									</h6>
									<button type="submit" class="btn btn-primary" name="save_card_widget">💾 Enregistrer</button>
								</div>

								{# ── Export iframe ── #}
								<div class="mt-3">
									<label for="cardIframeCode" class="form-label fw-semibold">Code iframe à intégrer sur votre site :</label>
									<div class="input-group">
										<input type="text" class="form-control font-monospace" id="cardIframeCode" readonly
											   value='<iframe src="{{ widgetCardUrl }}" width="720" height="400" frameborder="0" style="border:none;overflow:hidden;" scrolling="no" allowtransparency="true"></iframe>'>
										<button type="button" class="btn btn-outline-secondary" onclick="navigator.clipboard.writeText(document.getElementById('cardIframeCode').value);this.textContent='✅ Copié !';setTimeout(()=>this.textContent='📋 Copier',2000)">📋 Copier</button>
									</div>
								</div>
							</form>
						</div>
					</div>
				</div>
				{% endif %}

			</div>{# /accordion #}
		</div>
{% endblock %}
{% block scripts %}
	{% if viteEntries.admin.js %}
	<script type="module" src="/dist/{{ viteEntries.admin.js }}"></script>
	{% endif %}
	
	<script>
		var image = '{{ alertBoxWidgetPictureUrl }}';
		var message_template = '{{ alertBoxWidget.message_template | raw }}';
		var sound = '{{ alertBoxWidgetSoundUrl }}';
		var sound_volume = {{ alertBoxWidget.sound_volume / 100 }};
		var alert_duration = {{ alertBoxWidget.alert_duration * 1000 }};
	</script>

	{% if charityStream.is_test_mode %}
	<script>
	document.addEventListener('DOMContentLoaded', function() {
		document.getElementById('simulateDonationForm')?.addEventListener('submit', async function(e) {
			e.preventDefault();
			const pseudo = document.getElementById('sim_pseudo').value;
			const amount = Math.round(parseFloat(document.getElementById('sim_amount').value) * 100);
			const message = document.getElementById('sim_message').value;
			const alertBox = document.getElementById('simulateAlert');

			try {
				const resp = await fetch('/widget-stream/{{ charityStream.guid }}/simulate', {
					method: 'POST',
					headers: {'Content-Type': 'application/json'},
					body: JSON.stringify({ pseudo, amount, message })
				});
				const json = await resp.json();
				if (resp.ok) {
					document.getElementById('testAmountDisplay').textContent = (json.amount / 100).toLocaleString('fr-FR', {minimumFractionDigits: 2}) + ' €';
					alertBox.innerHTML = '<div class="alert alert-success alert-dismissible fade show py-1 px-2 mb-0"><small>✅ Don simulé : ' + pseudo + ' — ' + (amount/100) + ' €</small><button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button></div>';
					alertBox.style.display = 'block';
				} else {
					alertBox.innerHTML = '<div class="alert alert-danger py-1 px-2 mb-0"><small>❌ ' + (json.error || 'Erreur') + '</small></div>';
					alertBox.style.display = 'block';
				}
			} catch(err) {
				alertBox.innerHTML = '<div class="alert alert-danger py-1 px-2 mb-0"><small>❌ Erreur réseau</small></div>';
				alertBox.style.display = 'block';
			}
		});
	});
	</script>
	{% endif %}

{% endblock %}
