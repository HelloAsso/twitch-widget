{% block title %}HelloAsso Widgets - Administration{% endblock %}

{% extends "layout.html.twig" %}
{% block content %}

		<div class="modal fade" id="createEventModal" tabindex="-1">
			<div class="modal-dialog">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">Créer un nouvel évènement</h5>
						<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>
					<div class="modal-body">
						<form action="/admin/event" method="POST">
							<div class="mb-3">
								<label for="event_owner_email" class="form-label">Email du propriétaire</label>
								<input type="email" class="form-control" id="event_owner_email" name="owner_email" value="{{ ownerEmail }}" required>
							</div>
							<div class="mb-3">
								<label for="event_title" class="form-label">Titre</label>
								<input type="text" class="form-control" id="event_title" name="title" value="{{ title }}" required>
							</div>
							<button type="submit" class="btn btn-success" name="create_charity_event">Créer</button>
						</form>
					</div>
				</div>
			</div>
		</div>

		{# ── Modal création utilisateur ── #}
		<div class="modal fade" id="createUserModal" tabindex="-1">
			<div class="modal-dialog">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">Ajouter un utilisateur</h5>
						<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>
					<div class="modal-body">
						<form action="/admin/user" method="POST">
							<div class="mb-3">
								<label for="user_email" class="form-label">Email</label>
								<input type="email" class="form-control" id="user_email" name="user_email" placeholder="utilisateur@exemple.com" required>
								<div class="form-text">Un email de bienvenue sera envoyé avec un lien pour définir son mot de passe.</div>
							</div>
							<button type="submit" class="btn btn-success">✅ Créer l'utilisateur</button>
						</form>
					</div>
				</div>
			</div>
		</div>

	{% include 'stream/_modal-create-stream.html.twig' with { isAdmin: true } %}

		<div class="container">
			<h1 class="my-4 text-center">HelloAsso Widgets</h1>

			<div class="row my-4">
				<div class="col-10">
				<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createEventModal">
					Ajouter un évènement 👐
				</button>
				<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createStreamModal">
					Ajouter un stream 🎮
				</button>
				<button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
					Ajouter un utilisateur 👤
				</button>
				</div>
				<div class="col-2 text-end">
					<a href="/logout" class="btn btn-secondary mb-4">
						<i data-feather="log-in"></i>
						<span>Déconnexion</span>
					</a>
				</div>
			</div>

			{# ── Onglets ── #}
			<ul class="nav nav-tabs mb-3" id="adminTabs" role="tablist">
				<li class="nav-item" role="presentation">
					<button class="nav-link {{ activeTab == 'events' ? 'active' : '' }}" id="events-tab" data-bs-toggle="tab" data-bs-target="#events-pane" type="button" role="tab" aria-controls="events-pane" aria-selected="{{ activeTab == 'events' ? 'true' : 'false' }}">
						Évènements <span class="badge text-bg-secondary ms-1">{{ events|length }}</span>
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button class="nav-link {{ activeTab == 'streams' ? 'active' : '' }}" id="streams-tab" data-bs-toggle="tab" data-bs-target="#streams-pane" type="button" role="tab" aria-controls="streams-pane" aria-selected="{{ activeTab == 'streams' ? 'true' : 'false' }}">
						Streams <span class="badge text-bg-secondary ms-1">{{ streams|length }}</span>
					</button>
				</li>
				{% if users is defined %}
				<li class="nav-item" role="presentation">
					<button class="nav-link {{ activeTab == 'users' ? 'active' : '' }}" id="users-tab" data-bs-toggle="tab" data-bs-target="#users-pane" type="button" role="tab" aria-controls="users-pane" aria-selected="{{ activeTab == 'users' ? 'true' : 'false' }}">
						Utilisateurs <span class="badge text-bg-secondary ms-1">{{ users|length }}</span>
					</button>
				</li>
				{% endif %}
			</ul>

			<div class="tab-content" id="adminTabsContent">
				{# ── Onglet Évènements ── #}
				<div class="tab-pane fade {{ activeTab == 'events' ? 'show active' : '' }}" id="events-pane" role="tabpanel" aria-labelledby="events-tab">
					<table class="table table-hover align-middle">
						<thead>
							<tr>
								<th>Id</th>
								<th>Titre</th>
								<th>Admin</th>
								<th>Date de création</th>
								<th>Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for event in events %}
								<tr class="cursor-pointer" onclick="window.location='/admin/event/{{ event.guid }}/edit'" title="GUID : {{ event.guid }}">
									<td>{{ event.id | e }}</td>
									<td>{{ event.title | e }}</td>
									<td>{{ event.admin | e }}</td>
									<td>{{ event.creation_date ? event.creation_date|date('d/m/Y H:i') : '—' }}</td>
									<td class="d-flex gap-2" onclick="event.stopPropagation()">
										<a href="/admin/event/{{ event.guid }}/edit" class="btn btn-sm btn-outline-primary" data-bs-toggle="tooltip" data-bs-title="Édition">📝</a>
										<form action="/admin/event/{{ event.guid }}/delete" method="POST">
											<button type="submit" class="btn btn-sm btn-outline-danger" name="delete" data-bs-toggle="tooltip" data-bs-title="Suppression" onclick="confirmDelete(event)">🗑️</button>
										</form>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>

				{# ── Onglet Streams ── #}
				<div class="tab-pane fade {{ activeTab == 'streams' ? 'show active' : '' }}" id="streams-pane" role="tabpanel" aria-labelledby="streams-tab">
					<table class="table table-hover align-middle">
						<thead>
							<tr>
								<th>ID</th>
								<th>Titre</th>
								<th>Activité</th>
								<th>Admin</th>
								<th>Slug formulaire</th>
								<th>Slug association</th>
								<th>Date de création</th>
								<th>Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for stream in streams %}
								{% set activity = streamActivity[stream.guid] ?? null %}
								{% set amount = activity ? activity.amount : 0 %}
								{% set widgetLastUpdate = activity ? activity.widget_last_update : null %}
								<tr class="cursor-pointer" onclick="window.location='/admin/stream/{{ stream.guid }}/edit'" title="GUID : {{ stream.guid }}">
									<td>{{ stream.id | e }}</td>
									<td>
										{{ stream.title | e }}
										{% if stream.organization_slug in invalidTokenSlugs %}
											<span class="badge text-bg-warning ms-1" data-bs-toggle="tooltip" data-bs-title="Refresh token expiré ou absent — les widgets ne fonctionneront pas. Reconnectez l'association.">⚠️ Token invalide</span>
										{% endif %}
									</td>
									<td>
										{% if widgetLastUpdate and (date(widgetLastUpdate).timestamp > date('-5 minutes').timestamp) %}
											<span class="badge text-bg-success" data-bs-toggle="tooltip" data-bs-title="Widget consulté il y a moins de 5 min">🟢 En direct</span>
										{% elseif amount > 0 %}
											<span class="badge text-bg-info" data-bs-toggle="tooltip" data-bs-title="Dernière activité : {{ widgetLastUpdate ? widgetLastUpdate|date('d/m/Y H:i') : '—' }}">💰 {{ (amount / 100)|number_format(0, ',', ' ') }} €</span>
										{% else %}
											<span class="badge text-bg-secondary">⚪ Inactif</span>
										{% endif %}
									</td>
									<td>{{ stream.admin | e }}</td>
									<td>{{ stream.form_slug | e }}</td>
									<td>{{ stream.organization_slug | e }}</td>
									<td>{{ stream.creation_date ? stream.creation_date|date('d/m/Y H:i') : '—' }}</td>
									<td class="d-flex gap-2" onclick="event.stopPropagation()">
										<a href="/admin/stream/{{ stream.guid }}/edit" class="btn btn-sm btn-outline-primary" data-bs-toggle="tooltip" data-bs-title="Édition">📝</a>
										<a href="/redirect_auth_page?organizationSlug={{ stream.organization_slug }}" class="btn btn-sm btn-outline-success" data-bs-toggle="tooltip" data-bs-title="Mire d'authorisation" target="_blank">🔑</a>
										<form action="/admin/stream/{{ stream.guid }}/delete" method="POST">
											<button type="submit" class="btn btn-sm btn-outline-danger" name="delete" data-bs-toggle="tooltip" data-bs-title="Suppression" onclick="confirmDelete(event)">🗑️</button>
										</form>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>

				{# ── Onglet Utilisateurs ── #}
				{% if users is defined %}
				<div class="tab-pane fade {{ activeTab == 'users' ? 'show active' : '' }}" id="users-pane" role="tabpanel" aria-labelledby="users-tab">
					<table class="table table-hover align-middle">
						<thead>
							<tr>
								<th>ID</th>
								<th>Email</th>
								<th>Rôle</th>
								<th>Email vérifié</th>
								<th>Date de création</th>
								<th>Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for u in users %}
								<tr>
									<td>{{ u.id }}</td>
									<td>{{ u.email | e }}</td>
									<td>
										{% if u.role == 'ADMIN' %}
											<span class="badge text-bg-danger">Admin</span>
										{% else %}
											<span class="badge text-bg-secondary">Utilisateur</span>
										{% endif %}
									</td>
									<td>
										{% if u.email_verified %}
											<span class="badge text-bg-success">✅ Vérifié</span>
										{% else %}
											<span class="badge text-bg-warning">⏳ Non vérifié</span>
										{% endif %}
									</td>
									<td>{{ u.creation_date ? u.creation_date|date('d/m/Y H:i') : '—' }}</td>
									<td>
										{% if u.id != currentUser.id %}
											<form action="/admin/user/{{ u.id }}/delete" method="POST" class="d-inline">
												<button type="submit" class="btn btn-sm btn-outline-danger" data-bs-toggle="tooltip" data-bs-title="Supprimer" onclick="confirmDelete(event)">🗑️</button>
											</form>
										{% endif %}
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
				{% endif %}
			</div>
		</div>

	{% if messages['error'] %}
		<div class="toast-container position-fixed bottom-0 end-0 p-3">
			<div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
				<div class="toast-header">
					<strong class="me-auto">Erreur</strong>
					<button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
				</div>
				<div class="toast-body">
					{{ messages['error'][0] }}
				</div>
			</div>
		</div>
	{% endif %}

	{% if messages['success'] %}
		<div class="toast-container position-fixed bottom-0 end-0 p-3">
			<div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
				<div class="toast-header">
					<strong class="me-auto">Ok</strong>
					<button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
				</div>
				<div class="toast-body">
					{{ messages['success'][0] }}
				</div>
			</div>
		</div>
	{% endif %}
{% endblock %}
{% block styles %}
<style>
	/* ── Lignes de tableau cliquables ── */
	.cursor-pointer { cursor: pointer; }
	.table-hover tbody tr.cursor-pointer:hover {
		background-color: rgba(var(--bs-primary-rgb), .08) !important;
	}

	/* ── Cartes de sélection de mode ── */
	.stream-mode-card {
		cursor: pointer;
		transition: border-color .2s, box-shadow .2s, transform .1s;
		user-select: none;
	}
	.stream-mode-card:hover {
		border-color: var(--bs-primary) !important;
		box-shadow: 0 0 0 3px rgba(var(--bs-primary-rgb), .15);
		transform: translateY(-2px);
	}
	.stream-mode-card.active {
		border-color: var(--bs-success) !important;
		box-shadow: 0 0 0 3px rgba(var(--bs-success-rgb), .2);
		background-color: rgba(var(--bs-success-rgb), .06);
	}

	/* ── Stepper ── */
	.asso-step { display: flex; flex-direction: column; align-items: center; gap: 4px; }
	.step-bubble {
		width: 32px; height: 32px;
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		font-weight: 700; font-size: .85rem;
		background: var(--bs-secondary-bg);
		border: 2px solid var(--bs-secondary);
		color: var(--bs-secondary);
		transition: background .25s, border-color .25s, color .25s;
	}
	.asso-step.active .step-bubble {
		background: var(--bs-primary);
		border-color: var(--bs-primary);
		color: #fff;
	}
	.asso-step.done .step-bubble {
		background: var(--bs-success);
		border-color: var(--bs-success);
		color: #fff;
	}
	.step-label { font-size: .75rem; color: var(--bs-secondary); white-space: nowrap; }
	.asso-step.active .step-label,
	.asso-step.done  .step-label { color: var(--bs-body-color); font-weight: 600; }
	.step-line { height: 2px; background: var(--bs-secondary-bg); margin: 0 8px; margin-bottom: 18px; }

	/* ── Formulaires ── */
	.needs-validation .form-control:valid,
	.needs-validation .form-select:valid { border-color: var(--bs-success); }
	#createStreamModal .input-group-text { font-size: .75rem; }
</style>
{% endblock %}
{% block scripts %}
	{% include 'stream/_scripts-create-stream.html.twig' %}
{% endblock %}