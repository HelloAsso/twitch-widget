{% block title %}Card Widget{% endblock %}
{% extends "widget.html.twig" %}
{% block styles %}
<style>
	@import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap');

	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	body {
		background: transparent;
		font-family: 'Open Sans', sans-serif;
	}

	.card-widget {
		display: flex;
		max-width: 720px;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 4px 24px rgba(0,0,0,0.10);
	}

	.card-widget__image {
		flex: 0 0 260px;
		min-height: 340px;
		background-size: cover;
		background-position: center;
	}

	.card-widget__content {
		flex: 1;
		padding: 32px 36px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 16px;
	}

	.card-widget__tag {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 5px 14px;
		border-radius: 999px;
		width: fit-content;
	}

	.card-widget__tag svg {
		width: 14px;
		height: 14px;
	}

	.card-widget__title {
		font-size: 28px;
		font-weight: 800;
		line-height: 1.15;
	}

	.card-widget__description {
		font-size: 14px;
		line-height: 1.6;
		opacity: 0.8;
	}

	.card-widget__amount {
		font-size: 32px;
		font-weight: 800;
	}

	.card-widget__bar-wrapper {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.card-widget__bar {
		flex: 1;
		height: 12px;
		border-radius: 999px;
		overflow: hidden;
	}

	.card-widget__goal {
		font-size: 13px;
		white-space: nowrap;
	}

	.card-widget__goal strong {
		font-weight: 700;
	}

	.card-widget__stats {
		display: flex;
		gap: 24px;
		font-size: 13px;
		opacity: 0.75;
	}

	.card-widget__stats strong {
		font-weight: 700;
	}

	.card-widget__cta {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 13px;
		font-weight: 600;
		text-decoration: none;
		padding: 8px 20px;
		border-radius: 999px;
		transition: opacity 0.2s ease, transform 0.15s ease;
		width: fit-content;
		opacity: 0.85;
	}

	.card-widget__cta:hover {
		opacity: 1;
		transform: translateY(-1px);
	}

	.card-widget__cta svg {
		width: 14px;
		height: 14px;
		flex-shrink: 0;
	}

	.card-widget__bar-fill {
		height: 100%;
		border-radius: 999px;
		transition: width 1.5s ease;
		min-width: 2%;
	}

	@keyframes pulse {
		0% { transform: scale(1); }
		50% { transform: scale(1.2); }
		100% { transform: scale(1); }
	}

	.card-widget__pulse {
		animation: pulse 0.6s ease;
	}

	/* ── Fireworks overlay ───────────────────────── */
	#fireworks-overlay {
		position: fixed;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
		z-index: 100;
	}

	@keyframes fw-particle {
		0%   { transform: translate(0,0) scale(1); opacity: 1; }
		85%  { opacity: 1; }
		100% { transform: translate(var(--tx), var(--ty)) scale(0.2); opacity: 0; }
	}

	.fw-particle {
		position: absolute;
		width: 9px;
		height: 9px;
		border-radius: 50%;
		animation: fw-particle var(--dur) ease-out forwards;
	}

	@keyframes goal-banner {
		0%   { transform: translateY(-18px) scale(0.85); opacity: 0; }
		55%  { transform: translateY(3px) scale(1.04); opacity: 1; }
		80%  { transform: translateY(0) scale(1); opacity: 1; }
		100% { transform: translateY(0) scale(1); opacity: 0; }
	}

	.goal-banner {
		position: fixed;
		top: 18px;
		left: 50%;
		transform: translateX(-50%);
		background: rgba(0,0,0,0.82);
		color: #fff;
		font-family: 'Open Sans', sans-serif;
		font-size: 15px;
		font-weight: 700;
		padding: 10px 22px;
		border-radius: 999px;
		white-space: nowrap;
		animation: goal-banner 3.2s ease forwards;
		z-index: 101;
	}

	@keyframes goal-flash {
		0%,100% { opacity: 1; }
		30%      { opacity: 0.2; }
		60%      { opacity: 1; }
	}

	.card-widget__goal--flash {
		animation: goal-flash 0.7s ease;
	}
</style>
{% endblock %}
{% block content %}
	<div id="fireworks-overlay"></div>
	<div class="card-widget" style="background-color: {{ cardWidget.background_color }}; color: {{ cardWidget.text_color }}">
		{% if cardWidgetPictureUrl %}
		<div class="card-widget__image" style="background-image: url('{{ cardWidgetPictureUrl }}')"></div>
		{% endif %}
		<div class="card-widget__content">
			{% if cardWidget.tag %}
			<div class="card-widget__tag" style="color: {{ cardWidget.tag_color }}; background-color: {{ cardWidget.tag_background_color }}">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
				</svg>
				{{ cardWidget.tag }}
			</div>
			{% endif %}

			<div class="card-widget__title">{{ cardWidget.title }}</div>

			{% if cardWidget.description %}
			<div class="card-widget__description">{{ cardWidget.description }}</div>
			{% endif %}

			<div>
				<div class="card-widget__amount" id="card-amount">{{ currentAmount / 100 }} €</div>
				<div class="card-widget__bar-wrapper">
					<div class="card-widget__bar" style="background-color: {{ cardWidget.bar_background_color }}">
						<div class="card-widget__bar-fill" id="card-bar-fill"
							 style="background-color: {{ cardWidget.bar_color }}; width: {{ percentage }}%"></div>
					</div>
					<div class="card-widget__goal" id="card-goal-text">Objectif : <strong>{{ goal }} €</strong></div>
				</div>
				<div class="card-widget__stats">
					<span><strong id="card-percentage">{{ percentage }}%</strong> collectés</span>
					<span><strong id="card-donors">{{ donorCount }}</strong> donateurs</span>
				</div>
			</div>

			{% if donationUrl is defined and donationUrl %}
			<a href="{{ donationUrl }}" target="_blank" rel="noopener noreferrer" class="card-widget__cta"
			   style="color: {{ cardWidget.tag_color }}; background-color: {{ cardWidget.tag_background_color }};">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
				</svg>
				Je participe
			</a>
			{% endif %}
		</div>
	</div>
{% endblock %}
{% block scripts %}
	<script>
		window.goalAmount = {{ goal ?? 0 }};
		window.charityStreamId = '{{ cardWidget.charity_stream_guid }}';
		window.charityEventId = '{{ cardWidget.charity_event_guid }}';
		window.currentAmount = {{ currentAmount ?? 0 }};
		window.donorCount = {{ donorCount ?? 0 }};
	</script>
	{% if stream %}
		{% if viteEntries.cardStream.js %}
		<script type="module" src="/dist/{{ viteEntries.cardStream.js }}"></script>
		{% endif %}
	{% else %}
		{% if viteEntries.cardEvent.js %}
		<script type="module" src="/dist/{{ viteEntries.cardEvent.js }}"></script>
		{% endif %}
	{% endif %}
{% endblock %}

